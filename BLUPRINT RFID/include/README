# Quick Start

```cpp
#include "fm17660.h"
#include "rfid.h"

FM17660 fm17660(5);
RFID rfid(fm17660);

void setup()
{
    Serial.begin(115200);

    fm17660.begin();
    rfid.begin();
}

void loop()
{
    UID uid;

    if(rfid.readUID(uid))
    {
        uid.print(Serial);

        rfid.haltCard();

        delay(1000);
    }
}
```

